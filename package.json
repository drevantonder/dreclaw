{
  "name": "dreclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cf:deploy": "node scripts/wrangler-run.mjs deploy",
    "cf:dev": "node scripts/wrangler-run.mjs dev",
    "cf:d1:migrate": "node scripts/wrangler-run.mjs d1 migrations apply DRECLAW_DB",
    "live:telegram": "node scripts/telegram-live.mjs",
    "cf:secrets:sync": "node scripts/secrets-sync.mjs | node scripts/wrangler-run.mjs secret bulk",
    "smoke:live": "node scripts/smoke-live.mjs",
    "test:requirements": "vp test test/requirements --passWithNoTests",
    "test:supporting": "vp test test/supporting",
    "test:related": "vp test related",
    "cf:verify:predeploy": "vp check && vp test && vp run smoke:live",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@chat-adapter/telegram": "^4.18.0",
    "@cloudflare/codemode": "^0.2.2",
    "@cloudflare/shell": "^0.1.1",
    "ai": "^6.0.98",
    "chat": "^4.18.0",
    "telegram": "^2.26.22",
    "workers-ai-provider": "^3.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260215.0",
    "typescript": "^5.9.3",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.32.1"
}
