TELEGRAM_BOT_TOKEN=
AI_PROVIDER=zen
MODEL=kimi-k2.5-free
BASE_URL=https://opencode.ai/zen/v1
# Generate with: openssl rand -hex 32
# Use .env values (without printing them) when setting webhook:
# set -a; source .env; set +a
# curl "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook" \
#   -d "url=https://<worker-host>/telegram/webhook" \
#   -d "secret_token=${TELEGRAM_WEBHOOK_SECRET}"
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_ID=

OPENCODE_ZEN_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://<worker-host>/google/oauth/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/drive.file
# Generate with: openssl rand -base64 32
GOOGLE_OAUTH_ENCRYPTION_KEY=

# Workers AI mode (no API key needed when using env.AI binding):
# AI_PROVIDER=workers
# MODEL=@cf/zai-org/glm-4.7-flash

# Sync all vars above to Worker secrets:
# set -a; source .env; set +a
# pnpm secrets:sync
