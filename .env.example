TELEGRAM_BOT_TOKEN=
AI_PROVIDER=opencode-go
MODEL=kimi-k2.5
# Optional override. Defaults by provider:
# - opencode => https://opencode.ai/zen/v1
# - opencode-go => https://opencode.ai/zen/go/v1
BASE_URL=
# Generate with: openssl rand -hex 32
# Use .env values (without printing them) when setting webhook:
# set -a; source .env; set +a
# curl "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook" \
#   -d "url=https://<worker-host>/telegram/webhook" \
#   -d "secret_token=${TELEGRAM_WEBHOOK_SECRET}"
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_USER_ID=

# Optional local-only Telegram user test harness (GramJS)
TELEGRAM_TEST_API_ID=
TELEGRAM_TEST_API_HASH=
TELEGRAM_TEST_SESSION=
TELEGRAM_TEST_BOT_USERNAME=

OPENCODE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://<worker-host>/google/oauth/callback
GOOGLE_OAUTH_SCOPES="https://mail.google.com/ https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/documents https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/drive"
# Generate with: openssl rand -base64 32
GOOGLE_OAUTH_ENCRYPTION_KEY=

# Workers AI mode (no API key needed when using env.AI binding):
# AI_PROVIDER=workers
# MODEL=@cf/zai-org/glm-4.7-flash

# Memory (required when MEMORY_ENABLED=true)
MEMORY_ENABLED=true
MEMORY_RETENTION_DAYS=90
MEMORY_MAX_INJECT_TOKENS=1500
MEMORY_REFLECTION_EVERY_TURNS=8
MEMORY_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# Sync all vars above to Worker secrets:
# set -a; source .env; set +a
# pnpm secrets:sync

# Optional execute/VFS tuning (can also be set in wrangler vars):
# EXEC_TIMEOUT_MS=4000
# EXEC_MAX_LOG_LINES=120
# EXEC_MAX_OUTPUT_BYTES=65536
# NET_REQUEST_TIMEOUT_MS=10000
# NET_MAX_RESPONSE_BYTES=2097152
# VFS_MAX_FILE_BYTES=524288
# VFS_MAX_FILES=2000
# VFS_MAX_PATH_LENGTH=240
# VFS_LIST_LIMIT=500

# Optional model tuning:
# REASONING_EFFORT=medium
